# PITAS Environment Configuration
# Copy this file to .env and fill in real values

# ─── Site ────────────────────────────────────────────────────
SITE_URL=http://localhost:3000
PORT=3000

# ─── Admin ───────────────────────────────────────────────────
ADMIN_EMAIL=you@example.com

# ─── Email (Resend — recommended) ──────────────────────────────
# Resend gives much better deliverability than Gmail SMTP.
# 1. Sign up at https://resend.com (free tier: 3,000 emails/month)
# 2. Add and verify your domain (requires DNS TXT/CNAME records)
# 3. Set RESEND_API_KEY and RESEND_FROM_EMAIL below
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ─── Email (Gmail SMTP — fallback) ──────────────────────────
# Generate App Password: https://myaccount.google.com/apppasswords
# (Requires 2FA enabled on your Google account)
# NOTE: Gmail SMTP has poor deliverability — emails often land in spam.
GMAIL_USER=youremail@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
EMAIL_FROM_NAME=PITAS Tender Alert

# ─── AI (Groq) ───────────────────────────────────────────────
# Get free key: https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxx

# ─── Database ────────────────────────────────────────────────
DB_PATH=./data/pitas.db

# ─── Scraper ─────────────────────────────────────────────────
SCRAPE_DELAY_MS=3000
MAX_RETRIES=2
